          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.id) { pm.collectionVariables.set('bookingId', json.id); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
