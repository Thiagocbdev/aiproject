{
  "info": {
    "name": "ms-hotel-info",
    "description": "Hotel Info MS — porta 8081. Hóspede demo: João Silva (ID 11111111-1111-1111-1111-111111111111).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base", "value": "http://localhost:8081" },
    { "key": "guestId", "value": "11111111-1111-1111-1111-111111111111" },
    { "key": "bookingId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /actuator/health",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base}}/actuator/health", "host": ["{{base}}"], "path": ["actuator","health"] }
          }
        }
      ]
    },
    {
      "name": "Guests",
      "item": [
        {
          "name": "GET /api/v1/guests — listar todos",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base}}/api/v1/guests",
              "host": ["{{base}}"],
              "path": ["api","v1","guests"]
            }
          }
        },
        {
          "name": "GET /api/v1/guests?search= — buscar por nome",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base}}/api/v1/guests?search=João",
              "host": ["{{base}}"],
              "path": ["api","v1","guests"],
              "query": [{ "key": "search", "value": "João" }]
            }
          }
        },
        {
          "name": "GET /api/v1/guests/:guestId — hóspede demo",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base}}/api/v1/guests/{{guestId}}",
              "host": ["{{base}}"],
              "path": ["api","v1","guests","{{guestId}}"]
            }
          }
        },
        {
          "name": "POST /api/v1/guests — criar hóspede",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base}}/api/v1/guests",
              "host": ["{{base}}"],
              "path": ["api","v1","guests"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Maria Souza\",\n  \"email\": \"maria.souza@exemplo.com\",\n  \"phone\": \"+55 21 98888-7777\",\n  \"checkIn\": \"2026-07-15\",\n  \"checkOut\": \"2026-07-18\"\n}"
            }
          }
        }
