{
  "info": {
    "name": "ms-hotel-info",
    "description": "Hotel data microservice — guests, rooms, bookings, pricing (porta 8081)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8081" },
    { "key": "guestId", "value": "{{guestId}}" },
    { "key": "bookingId", "value": "{{bookingId}}" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/actuator/health"
          }
        }
      ]
    },
    {
      "name": "Guests",
      "item": [
        {
          "name": "List all guests",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/guests"
          }
        },
        {
          "name": "Search guests by name",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/guests?search=João",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "guests"],
              "query": [
                { "key": "search", "value": "João" }
              ]
            }
          }
        },
        {
          "name": "Get guest by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/guests/{{guestId}}"
          }
        },
        {
          "name": "Create guest",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/guests",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Maria Silva\",\n  \"email\": \"maria@example.com\",\n  \"phone\": \"+55 11 99999-0000\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Rooms",
      "item": [
        {
          "name": "List all rooms",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/rooms"
          }
        },
        {
          "name": "List rooms by type",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/rooms?type=SUITE",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "rooms"],
              "query": [
                { "key": "type", "value": "SUITE", "description": "STANDARD | DELUXE | SUITE" }
              ]
            }
          }
        },
        {
          "name": "Check service availability",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/rooms/spa/availability?date=2026-07-15&time=14:00",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "rooms", "spa", "availability"],
              "query": [
                { "key": "date", "value": "2026-07-15" },
                { "key": "time", "value": "14:00" }
              ]
            },
            "description": "serviceType path param: spa | restaurant | gym | room_service"
          }
        }
      ]
    },
    {
      "name": "Pricing",
      "item": [
        {
          "name": "Get service price",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/pricing?serviceType=spa&date=2026-07-15",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "pricing"],
              "query": [
                { "key": "serviceType", "value": "spa", "description": "spa | restaurant | gym | room_service" },
                { "key": "date", "value": "2026-07-15" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "List all bookings",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/bookings"
          }
        },
        {
          "name": "List bookings by guest",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/bookings?guestId={{guestId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "bookings"],
              "query": [{ "key": "guestId", "value": "{{guestId}}" }]
            }
          }
        },
        {
          "name": "Get booking by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/bookings/{{bookingId}}"
          }
        },
        {
          "name": "Create booking",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/bookings",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"guestId\": \"{{guestId}}\",\n  \"serviceTypeId\": \"uuid-do-serviceType-obtido-via-listRooms\",\n  \"scheduledAt\": \"2026-07-16T18:00:00\",\n  \"durationMinutes\": 60,\n  \"notes\": \"Preferência por massagem relaxante\"\n}"
            }
          }
        },
        {
          "name": "Update booking status",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/api/v1/bookings/{{bookingId}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"CONFIRMED\"\n}",
              "options": {
                "raw": {
                  "language": "text"
                }
              }
            },
            "description": "status: CONFIRMED | CANCELLED | COMPLETED"
          }
        }
      ]
    }
  ]
}
